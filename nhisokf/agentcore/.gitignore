# Secrets (local environment files are never committed)
.env.local

# CDK Build Artifacts
cdk/cdk.out/
cdk/node_modules/

# CLI Internals (deploy/invoke logs + deployed-state.json — contains the AWS account id and
# runtime ARNs; kept OUT of this PUBLIC repo, unlike the CLI default which commits the state)
.cli/

# Ephemeral Staging
.cache/*

# Deployment target — contains the AWS account id; not committed to a public repo.
aws-targets.json
