# Raw microdata (large public-use files; fetched via `nhis fetch`, not committed)
data/
*.csv
*.zip

# Python
.venv/
**/.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Local secrets
.env

# Run working state (kept local, not committed product source — see Baton Run Artifacts)
.agents/

# macOS
.DS_Store

# AgentCore CLI generated / heavy / secret / build artifacts (only the hand-authored
# config, thin shim, and app project are tracked)
agentcore/cdk/
agentcore/.cache/
agentcore/node_modules/
agentcore/.venv/
agentcore/.env.local
agentcore/*/staging/
app/**/.venv/
app/**/staging/
app/**/*.egg-info/
